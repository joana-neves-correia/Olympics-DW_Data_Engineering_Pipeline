          DTS:DTSID="{4D47AE25-FC37-4E94-9508-6E2A2F0D802C}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Execute SQL Task"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2025; © 2025 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{80B01BFB-3269-494E-879C-4D24485FFF5C}"
              SQLTask:SqlStatementSource="MERGE dbo.Fact_Olimpiadas AS T&#xA;USING (&#xA;    SELECT *&#xA;    FROM (&#xA;        SELECT *,&#xA;               ROW_NUMBER() OVER (&#xA;                   PARTITION BY ID_Atleta, NOC, Games, ID_Mod, Medal&#xA;                   ORDER BY DW_updated_on DESC&#xA;               ) AS rn&#xA;        FROM dbo.Fact_Staging_Olimpiadas&#xA;    ) X&#xA;    WHERE rn = 1&#xA;) AS S&#xA;ON  T.ID_Atleta = S.ID_Atleta&#xA;AND T.NOC       = S.NOC&#xA;AND T.Games     = S.Games&#xA;AND T.ID_Mod    = S.ID_Mod&#xA;AND ISNULL(T.Medal,'NA') = ISNULL(S.Medal,'NA')&#xA;&#xA;WHEN MATCHED&#xA;    AND ISNULL(T.DW_row_checksum,'') &lt;&gt; ISNULL(S.DW_row_checksum,'')&#xA;THEN&#xA;    UPDATE SET&#xA;        T.Medal = S.Medal,&#xA;        T.DW_row_checksum = S.DW_row_checksum,&#xA;        T.DW_run_id = S.DW_run_id,&#xA;        T.DW_updated_on = S.DW_updated_on,&#xA;        T.DW_source_system = S.DW_source_system&#xA;&#xA;WHEN NOT MATCHED BY TARGET&#xA;THEN&#xA;    INSERT (&#xA;        ID_Atleta, NOC, Games, ID_Mod, Medal,&#xA;        DW_row_checksum, DW_run_id, DW_updated_on, DW_source_system&#xA;    )&#xA;    VALUES (&#xA;        S.ID_Atleta, S.NOC, S.Games, S.ID_Mod, S.Medal,&#xA;        S.DW_row_checksum, S.DW_run_id, S.DW_updated_on, S.DW_source_system&#xA;    );" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
